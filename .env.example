# Required: local Obsidian vault root
OBSIDIAN_VAULT_PATH=D:/Knowledge/MyVault

# Optional: local LLM via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional: cloud LLM fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Runtime options
LOG_LEVEL=info
BACKUP_DIR=.backups
RAG_INDEX_DIR=.cache/rag
