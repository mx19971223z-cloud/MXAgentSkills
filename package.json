{
  "name": "agentskills-obsidianmcp",
  "version": "1.0.0",
  "description": "AgentSkills - ObsidianMCP intelligent skill engine for local knowledge workflows.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentskills": "dist/cli/skill-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp/server.ts",
    "skill": "tsx src/cli/skill-cli.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "agent",
    "skills",
    "rag",
    "ollama"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "markdown-it": "^14.1.0",
    "obsidian": "^1.8.9",
    "ollama": "^0.5.16",
    "openai": "^4.104.0",
    "pdfkit": "^0.17.2"
  },
  "optionalDependencies": {
    "faiss-node": "^0.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.3.0",
    "@types/pdfkit": "^0.17.3",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  }
}